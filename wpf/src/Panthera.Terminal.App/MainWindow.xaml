<Window x:Class="Panthera.Terminal.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Panthera.Terminal.Controls;assembly=Panthera.Terminal.Controls"
        Title="Panthera WAM · Fluent Cockpit" Width="1720" Height="1020"
        MinWidth="1380" MinHeight="820" WindowStartupLocation="CenterScreen">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="180" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="14,10" CornerRadius="14" Margin="0,0,0,9"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <ComboBox Width="104" Margin="5,4" SelectedValuePath="Content"
                              SelectedValue="{Binding Theme}" SelectionChanged="Theme_SelectionChanged">
                        <ComboBoxItem Content="System" />
                        <ComboBoxItem Content="Light" />
                        <ComboBoxItem Content="Dark" />
                    </ComboBox>
                    <Button Content="环境检测" Command="{Binding ProbeEnvironmentCommand}" />
                    <Button Content="一键引导" Click="RunEnvironment_Click" Background="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" Foreground="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}" />
                    <Button Content="复位急停" Command="{Binding ClearEStopCommand}" />
                    <Button Content="E-STOP" Command="{Binding TriggerEStopCommand}"
                            Background="#C42B1C" Foreground="White" FontWeight="Bold"
                            MinWidth="116" MinHeight="44" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,18,0">
                        <TextBlock Text="Panthera WAM" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="ROBOT CONTROL TERMINAL" FontSize="10" Opacity="0.62" FontWeight="SemiBold" />
                    </StackPanel>
                    <Border CornerRadius="12" Padding="10,5" Margin="3" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                        <TextBlock Text="{Binding ConnectionState}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Border>
                    <Border CornerRadius="12" Padding="10,5" Margin="3" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                        <TextBlock Text="{Binding DaemonSummary}" VerticalAlignment="Center" />
                    </Border>
                    <Border CornerRadius="12" Padding="10,5" Margin="3" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="控制权  " Opacity="0.65" />
                            <TextBlock Text="{Binding ControlHolder}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Button Content="获取控制" Command="{Binding AcquireControlCommand}" />
                    <Button Content="释放" Command="{Binding ReleaseControlCommand}" />
                    <TextBlock Text="{Binding StateAgeMs, StringFormat={}LIVE · {0} ms}" Margin="12,0,0,0" FontFamily="Consolas" VerticalAlignment="Center" Opacity="0.72" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 三列主区：紧凑关节卡片 / 三投影视图 / 全部操作卡片。 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.08*" MinWidth="450" />
                <ColumnDefinition Width="0.96*" MinWidth="380" />
                <ColumnDefinition Width="1.12*" MinWidth="450" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="六关节状态">
                <ItemsControl ItemsSource="{Binding Joints}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" Rows="3" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:JointGauge Margin="4"
                                                 Title="{Binding Name}"
                                                 Position="{Binding Position}"
                                                 Minimum="{Binding Minimum}"
                                                 Maximum="{Binding Maximum}"
                                                 Velocity="{Binding Velocity}"
                                                 Torque="{Binding Torque}"
                                                 StatusText="{Binding StatusText}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </GroupBox>

            <Grid Grid.Column="1" Margin="2,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <controls:ArmProjectionView Grid.Row="0" Margin="5" ViewMode="Top"
                                            X="{Binding TcpX}" Y="{Binding TcpY}" Z="{Binding TcpZ}" />
                <controls:ArmProjectionView Grid.Row="1" Margin="5" ViewMode="Side"
                                            X="{Binding TcpX}" Y="{Binding TcpY}" Z="{Binding TcpZ}" />
                <controls:ArmProjectionView Grid.Row="2" Margin="5" ViewMode="Front"
                                            X="{Binding TcpX}" Y="{Binding TcpY}" Z="{Binding TcpZ}" />
            </Grid>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <GroupBox Header="关节点动 · MoveJ">
                        <StackPanel>
                            <DockPanel Margin="3">
                                <TextBlock Text="按住持续运动，松开或窗口失焦立即停止" VerticalAlignment="Center" Opacity="0.7" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock Text="速度" VerticalAlignment="Center" />
                                    <Slider Width="120" Minimum="0.02" Maximum="0.35" Value="{Binding JogSpeed}" Margin="8,0" />
                                </StackPanel>
                            </DockPanel>
                            <UniformGrid Columns="4" Rows="3">
                                <controls:JogButton Content="J1 −" JogParameter="0:-1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                <controls:JogButton Content="J1 +" JogParameter="0:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                <controls:JogButton Content="J2 −" JogParameter="1:-1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                <controls:JogButton Content="J2 +" JogParameter="1:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                <controls:JogButton Content="J3 −" JogParameter="2:-1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                <controls:JogButton Content="J3 +" JogParameter="2:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                <controls:JogButton Content="J4 −" JogParameter="3:-1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                <controls:JogButton Content="J4 +" JogParameter="3:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                <controls:JogButton Content="J5 −" JogParameter="4:-1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                <controls:JogButton Content="J5 +" JogParameter="4:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                <controls:JogButton Content="J6 −" JogParameter="5:-1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                <controls:JogButton Content="J6 +" JogParameter="5:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                            </UniformGrid>
                            <UniformGrid Columns="6" Margin="0,5,0,0">
                                <TextBox Text="{Binding TargetJ1}" ToolTip="J1 rad" />
                                <TextBox Text="{Binding TargetJ2}" ToolTip="J2 rad" />
                                <TextBox Text="{Binding TargetJ3}" ToolTip="J3 rad" />
                                <TextBox Text="{Binding TargetJ4}" ToolTip="J4 rad" />
                                <TextBox Text="{Binding TargetJ5}" ToolTip="J5 rad" />
                                <TextBox Text="{Binding TargetJ6}" ToolTip="J6 rad" />
                            </UniformGrid>
                            <Button Content="MoveJ 到目标关节" Command="{Binding MoveJCommand}" HorizontalAlignment="Stretch"
                                    Background="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                                    Foreground="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="笛卡尔坐标 · MoveL">
                        <StackPanel>
                            <TextBlock Text="当前位置" FontWeight="SemiBold" />
                            <TextBlock FontFamily="Consolas" Margin="3"
                                       Text="{Binding TcpX, StringFormat={}X {0:F4} m}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Consolas" Margin="3" Text="{Binding TcpY, StringFormat={}Y {0:F4} m}" />
                                <TextBlock FontFamily="Consolas" Margin="3" Text="{Binding TcpZ, StringFormat={}Z {0:F4} m}" />
                            </StackPanel>
                            <TextBlock Text="目标 X / Y / Z / Roll / Pitch / Yaw" FontWeight="SemiBold" Margin="3,5,0,0" />
                            <UniformGrid Columns="3" Rows="2">
                                <TextBox Text="{Binding TargetX}" ToolTip="X m" />
                                <TextBox Text="{Binding TargetY}" ToolTip="Y m" />
                                <TextBox Text="{Binding TargetZ}" ToolTip="Z m" />
                                <TextBox Text="{Binding TargetRoll}" ToolTip="Roll rad" />
                                <TextBox Text="{Binding TargetPitch}" ToolTip="Pitch rad" />
                                <TextBox Text="{Binding TargetYaw}" ToolTip="Yaw rad" />
                            </UniformGrid>
                            <CheckBox Content="保持当前末端姿态（推荐）" IsChecked="{Binding PreserveOrientation}"
                                      Margin="5,3" />
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="取消" Command="{Binding CancelExecutionCommand}" />
                                <Button DockPanel.Dock="Right" Content="MoveL" Command="{Binding MoveLCommand}" />
                                <ProgressBar Height="18" Margin="3" Maximum="1" Value="{Binding ExecutionFraction}" />
                            </DockPanel>
                            <TextBlock Text="{Binding ExecutionStatus}" Margin="3" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="夹爪" Height="86">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="打开" Command="{Binding GripperOpenCommand}" />
                            <Button Grid.Column="1" Content="闭合" Command="{Binding GripperCloseCommand}" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="D405 摄像头" Height="165">
                        <Grid>
                            <Border Margin="5" BorderBrush="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" BorderThickness="1" CornerRadius="8">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="▣" FontWeight="Bold" FontSize="28" HorizontalAlignment="Center" Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                                    <TextBlock Text="D405 预览通道" Margin="0,4,0,0" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    <TextBlock Text="v2 接入视频流；当前不影响机械臂控制" FontSize="11" Opacity="0.7" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Expander Grid.Row="2" Header="环境引导明细（命令全文可审计）" IsExpanded="False" Margin="0,5">
            <ListView ItemsSource="{Binding EnvironmentSteps}" MaxHeight="150">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="步骤" Width="120" DisplayMemberBinding="{Binding Name}" />
                        <GridViewColumn Header="结果" Width="70" DisplayMemberBinding="{Binding Success}" />
                        <GridViewColumn Header="说明" Width="420" DisplayMemberBinding="{Binding Detail}" />
                        <GridViewColumn Header="命令" Width="700" DisplayMemberBinding="{Binding Command}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Expander>

        <GroupBox Grid.Row="3" Header="运行日志">
            <ListView ItemsSource="{Binding Logs}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="时间" Width="105" DisplayMemberBinding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss.fff}}" />
                        <GridViewColumn Header="级别" Width="75" DisplayMemberBinding="{Binding Level}" />
                        <GridViewColumn Header="来源" Width="110" DisplayMemberBinding="{Binding Source}" />
                        <GridViewColumn Header="消息" Width="1200" DisplayMemberBinding="{Binding Message}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>
    </Grid>
</Window>
