<UserControl x:Class="Panthera.Terminal.App.CadThreeView" x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="620" MinHeight="400"
             Focusable="False" KeyboardNavigation.IsTabStop="False">
    <Grid ClipToBounds="True" Background="{DynamicResource ControlFillColorTertiaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="10,0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="精确 CAD 三视图" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="SIDE · FRONT · TOP" Margin="10,0,0,0"
                           FontFamily="Cascadia Mono, Consolas" FontSize="11.5"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="TCP" Margin="0,0,8,0" FontFamily="Cascadia Mono, Consolas" FontSize="11"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                    <Border Padding="6,3" CornerRadius="4" Margin="0,0,5,0" Background="#14C42B1C">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="X" Margin="0,0,5,0" Foreground="#FFC42B1C" FontFamily="Cascadia Mono, Consolas" FontSize="11.5" FontWeight="Bold" />
                            <TextBlock Text="{Binding TcpX, ElementName=Root, StringFormat={}{0:+0.000;-0.000;+0.000}}" FontFamily="Cascadia Mono, Consolas" FontSize="11.5" />
                        </StackPanel>
                    </Border>
                    <Border Padding="6,3" CornerRadius="4" Margin="0,0,5,0" Background="#140F7B0F">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Y" Margin="0,0,5,0" Foreground="#FF0F7B0F" FontFamily="Cascadia Mono, Consolas" FontSize="11.5" FontWeight="Bold" />
                            <TextBlock Text="{Binding TcpY, ElementName=Root, StringFormat={}{0:+0.000;-0.000;+0.000}}" FontFamily="Cascadia Mono, Consolas" FontSize="11.5" />
                        </StackPanel>
                    </Border>
                    <Border Padding="6,3" CornerRadius="4" Background="#140067C0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Z" Margin="0,0,5,0" Foreground="#FF0067C0" FontFamily="Cascadia Mono, Consolas" FontSize="11.5" FontWeight="Bold" />
                            <TextBlock Text="{Binding TcpZ, ElementName=Root, StringFormat={}{0:+0.000;-0.000;+0.000} m}" FontFamily="Cascadia Mono, Consolas" FontSize="11.5" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="显示" FontSize="11.5" Margin="0,0,6,0"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                    <ComboBox x:Name="StylePicker" Width="102" Height="34" Padding="8,0" FontFamily="Microsoft YaHei UI, Segoe UI" FontSize="13"
                              VerticalContentAlignment="Center" HorizontalContentAlignment="Stretch" SelectionChanged="StylePicker_SelectionChanged"
                              AutomationProperties.AutomationId="CadStyleSelector">
                        <ComboBoxItem Content="工程草图" Tag="sketch" />
                        <ComboBoxItem Content="实体" Tag="solid" />
                        <ComboBoxItem Content="材质" Tag="material" IsSelected="True" />
                        <ComboBoxItem Content="渲染" Tag="rendered" />
                        <ComboBoxItem Content="蓝图" Tag="blueprint" />
                        <ComboBoxItem Content="X-Ray" Tag="xray" />
                        <ComboBoxItem Content="线框" Tag="wireframe" />
                    </ComboBox>
                    <ComboBox x:Name="CameraPicker" Width="102" Height="34" Padding="8,0" FontFamily="Microsoft YaHei UI, Segoe UI" FontSize="13" Margin="5,0,0,0"
                              VerticalContentAlignment="Center" HorizontalContentAlignment="Stretch"
                              SelectionChanged="CameraPicker_SelectionChanged"
                              AutomationProperties.AutomationId="CadCameraSelector">
                        <ComboBoxItem Content="固定基座" Tag="fixed-base" IsSelected="True" />
                        <ComboBoxItem Content="跟随运动" Tag="follow" />
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="BrowserHost" Grid.Row="1" />

        <Border x:Name="LoadingOverlay" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="12,8" CornerRadius="7"
                Background="{DynamicResource AcrylicBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <ProgressBar Width="82" Height="4" IsIndeterminate="True" VerticalAlignment="Center" />
                <TextBlock x:Name="LoadingText" Text="正在初始化精确 CAD…" Margin="10,0,0,0"
                           FontSize="11" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
