<ui:FluentWindow x:Class="Panthera.Terminal.App.SshDeploymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="SSH 远程部署配置"
        Width="570" Height="470" MinWidth="520" MinHeight="430"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowBackdropType="Mica" WindowCornerPreference="Round"
        FontFamily="Segoe UI Variable Text, Microsoft YaHei UI, Segoe UI"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        AutomationProperties.AutomationId="SshDeploymentDialog">
    <Grid Margin="24,18,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="远程部署与连接" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Margin="0,7,0,0" TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="输入已有 SSH 连接信息。终端会自动识别 Raspberry Pi / WSL、定位已经部署的 Panthera-WAM 工作区和启动方式；不会克隆仓库、安装依赖或修改远程源码。" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,14,0,12" Padding="10,8" CornerRadius="6"
                Background="{DynamicResource ControlFillColorTertiaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
            <TextBlock TextWrapping="Wrap" FontSize="12.5"
                       Text="认证使用 Windows OpenSSH 的默认密钥、ssh-agent 或下方指定的私钥。终端不保存 SSH 密码。首次连接可自动接受新的主机指纹，但不会接受已变化的指纹。" />
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="115" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="48" />
                <RowDefinition Height="48" />
                <RowDefinition Height="48" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <TextBlock Text="SSH 主机" VerticalAlignment="Center" />
            <TextBox x:Name="HostBox" Grid.Column="1" Grid.ColumnSpan="2" Height="34"
                     VerticalContentAlignment="Center" AutomationProperties.AutomationId="SshHostBox" />

            <TextBlock Grid.Row="1" Text="端口" VerticalAlignment="Center" />
            <TextBox x:Name="PortBox" Grid.Row="1" Grid.Column="1" Width="110" Height="34"
                     HorizontalAlignment="Left" VerticalContentAlignment="Center"
                     AutomationProperties.AutomationId="SshPortBox" />

            <TextBlock Grid.Row="2" Text="用户名" VerticalAlignment="Center" />
            <TextBox x:Name="UserBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Height="34"
                     VerticalContentAlignment="Center" AutomationProperties.AutomationId="SshUserBox" />

            <TextBlock Grid.Row="3" Text="私钥文件（可选）" VerticalAlignment="Center" />
            <TextBox x:Name="IdentityFileBox" Grid.Row="3" Grid.Column="1" Height="34"
                     Margin="0,0,7,0" VerticalContentAlignment="Center"
                     AutomationProperties.AutomationId="SshIdentityFileBox" />
            <ui:Button Grid.Row="3" Grid.Column="2" Content="浏览" Height="34"
                       Appearance="Secondary" Click="BrowseIdentity_Click"
                       AutomationProperties.AutomationId="BrowseSshIdentityButton" />

            <CheckBox x:Name="AcceptHostKeyBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                      Content="自动接受首次出现的主机指纹（accept-new）"
                      VerticalAlignment="Center" AutomationProperties.AutomationId="AcceptSshHostKeyBox" />
        </Grid>

        <TextBlock x:Name="ValidationText" Grid.Row="3" MinHeight="24" Margin="0,4,0,8"
                   TextWrapping="Wrap" Foreground="{DynamicResource SystemFillColorCriticalBrush}" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Content="取消" Width="88" Height="36" Appearance="Secondary"
                       IsCancel="True" AutomationProperties.AutomationId="CancelSshDeploymentButton" />
            <ui:Button Content="探测并启动" Width="122" Height="36" Margin="8,0,0,0"
                       Appearance="Primary" Click="Submit_Click"
                       AutomationProperties.AutomationId="SubmitSshDeploymentButton" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
