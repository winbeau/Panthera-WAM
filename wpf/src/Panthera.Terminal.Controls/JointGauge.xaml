<UserControl x:Class="Panthera.Terminal.Controls.JointGauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="214" MinHeight="128">
    <Border Padding="10" CornerRadius="12" Margin="2"
            Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
            BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
            BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="112" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid Width="108" Height="108">
                <Ellipse Margin="5" Stroke="{DynamicResource {x:Static SystemColors.InactiveBorderBrushKey}}" StrokeThickness="7" />
                <Ellipse Margin="14" Stroke="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" StrokeThickness="2.5" />
                <Line X1="54" Y1="54" X2="54" Y2="18" StrokeThickness="3"
                      Stroke="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                      RenderTransformOrigin="0.5,0.5">
                    <Line.RenderTransform>
                        <RotateTransform Angle="{Binding AngleDegrees, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    </Line.RenderTransform>
                </Line>
                <Ellipse Width="9" Height="9" Fill="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,28,0,0">
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding PositionDegrees, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat={}{0:F1}°}"
                               FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding StatusText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               FontSize="10" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- 速度与力矩纵向同列，压缩单个关节卡片宽度。 -->
            <StackPanel Grid.Column="1" Margin="8,2,0,2" VerticalAlignment="Center">
                <TextBlock Text="SPEED" FontSize="10" FontWeight="SemiBold" Opacity="0.7" />
                <ProgressBar Height="9" Margin="0,3,0,2" Maximum="1.5"
                             Value="{Binding SpeedMagnitude, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                <TextBlock Text="{Binding Velocity, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat={}{0:F3} rad/s}"
                           FontFamily="Consolas" FontSize="10" Margin="0,0,0,8" />
                <TextBlock Text="TORQUE" FontSize="10" FontWeight="SemiBold" Opacity="0.7" />
                <ProgressBar Height="9" Margin="0,3,0,2" Maximum="40"
                             Value="{Binding TorqueMagnitude, Mode=OneWay, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                <TextBlock Text="{Binding Torque, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat={}{0:F2} N·m}"
                           FontFamily="Consolas" FontSize="10" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
