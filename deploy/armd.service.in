[Unit]
Description=Panthera-WAM hardware control daemon
After=default.target

[Service]
Type=simple
WorkingDirectory=@REPO_ROOT@
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=-%h/.config/panthera-wam/armd.env
ExecStart=/usr/bin/env uv run --package panthera-armd armd --bind 127.0.0.1:50051
Restart=on-failure
RestartSec=2
KillSignal=SIGINT
TimeoutStopSec=5

[Install]
WantedBy=default.target
