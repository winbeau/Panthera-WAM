<ui:FluentWindow x:Class="Panthera.Terminal.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Panthera.Terminal.Controls;assembly=Panthera.Terminal.Controls"
        xmlns:local="clr-namespace:Panthera.Terminal.App"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Panthera-HT 控制终端"
        Width="1680" Height="1040" MinWidth="1240" MinHeight="800"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="None" WindowCornerPreference="Round"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        WindowStartupLocation="CenterScreen" UseLayoutRounding="True"
        SnapsToDevicePixels="True" KeyboardNavigation.TabNavigation="Cycle">
    <ui:FluentWindow.Resources>
        <Style x:Key="CardHeaderStyle" TargetType="Border">
            <Setter Property="Padding" Value="11,8" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style x:Key="MetricCellStyle" TargetType="Border" BasedOn="{StaticResource CockpitSubtlePanelStyle}">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="3" />
        </Style>
        <Style x:Key="InputStackStyle" TargetType="StackPanel">
            <Setter Property="Margin" Value="3" />
        </Style>
        <Style x:Key="StatusDotStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="7" />
            <Setter Property="Height" Value="7" />
            <Setter Property="Fill" Value="{DynamicResource TextFillColorTertiaryBrush}" />
        </Style>
        <Style x:Key="MainTabStyle" TargetType="RadioButton">
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder" Padding="14,0" CornerRadius="6"
                                Background="Transparent" BorderBrush="Transparent" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="F12" Command="{Binding TriggerEStopCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelExecutionCommand}" />
        <KeyBinding Key="OemMinus" Modifiers="Control" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Key="Subtract" Modifiers="Control" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Key="OemPlus" Modifiers="Control" Command="{Binding ZoomInCommand}" />
        <KeyBinding Key="Add" Modifiers="Control" Command="{Binding ZoomInCommand}" />
        <KeyBinding Key="D0" Modifiers="Control" Command="{Binding ResetZoomCommand}" />
    </ui:FluentWindow.InputBindings>

    <Grid Background="{DynamicResource ApplicationBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="54" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="27" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Panthera WAM v2">
            <ui:TitleBar.Icon><ui:SymbolIcon Symbol="DesktopPulse24" /></ui:TitleBar.Icon>
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="LINUX UNIFIED" Margin="0,0,10,0" FontFamily="Cascadia Mono, Consolas"
                               Foreground="{DynamicResource SystemFillColorSuccessBrush}" FontSize="10" />
                    <TextBlock Text="WPF VISUAL TERMINAL" Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="10" />
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <Border Grid.Row="1" Background="{DynamicResource LayerFillColorAltBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton x:Name="ControlTabButton" Content="控制与三视图" GroupName="MainTabs"
                                 Style="{StaticResource MainTabStyle}" IsChecked="True" Tag="Control"
                                 Checked="MainTab_Checked" AutomationProperties.AutomationId="ControlTabButton" />
                    <RadioButton x:Name="DataTabButton" Content="D405 与数据采集" GroupName="MainTabs"
                                 Style="{StaticResource MainTabStyle}" Tag="Data"
                                 Checked="MainTab_Checked" AutomationProperties.AutomationId="DataTabButton" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Margin="0,0,6,0" Style="{StaticResource CockpitBadgeStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Margin="0,0,6,0">
                                <Ellipse.Style><Style TargetType="Ellipse" BasedOn="{StaticResource StatusDotStyle}"><Style.Triggers><DataTrigger Binding="{Binding IsConnected}" Value="True"><Setter Property="Fill" Value="{DynamicResource SystemFillColorSuccessBrush}" /></DataTrigger></Style.Triggers></Style></Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="机械臂 " FontSize="10.5" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ConnectionLabel}" FontFamily="Cascadia Mono, Consolas" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,6,0" Style="{StaticResource CockpitBadgeStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Margin="0,0,6,0" Style="{StaticResource StatusDotStyle}" Fill="{DynamicResource SystemFillColorSuccessBrush}" />
                            <TextBlock Text="D405 " FontSize="10.5" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding CameraSummary}" MaxWidth="130" TextTrimming="CharacterEllipsis"
                                       FontFamily="Cascadia Mono, Consolas" FontSize="9.5" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,6,0" Style="{StaticResource CockpitBadgeStyle}">
                        <TextBlock Text="{Binding LiveSummary}" FontFamily="Cascadia Mono, Consolas" FontSize="10" VerticalAlignment="Center" />
                    </Border>
                    <ui:Button Content="−" Width="30" Height="30" Appearance="Secondary" Command="{Binding ZoomOutCommand}" ToolTip="Ctrl+-" />
                    <TextBlock Text="{Binding UiScaleLabel}" Width="45" HorizontalAlignment="Center" TextAlignment="Center"
                               VerticalAlignment="Center" FontFamily="Cascadia Mono, Consolas" FontSize="10" />
                    <ui:Button Content="+" Width="30" Height="30" Appearance="Secondary" Command="{Binding ZoomInCommand}" ToolTip="Ctrl++" />
                    <ui:Button Content="重置" Height="30" Appearance="Transparent" Command="{Binding ResetZoomCommand}" Margin="3,0,4,0" />
                    <ComboBox Width="86" Height="32" Margin="0,0,5,0" SelectedValuePath="Content"
                              SelectedValue="{Binding Theme}" SelectionChanged="Theme_SelectionChanged"
                              AutomationProperties.AutomationId="ThemeSelector">
                        <ComboBoxItem Content="System" /><ComboBoxItem Content="Light" /><ComboBoxItem Content="Dark" />
                    </ComboBox>
                    <ui:Button Content="复位" Icon="{ui:SymbolIcon ArrowSync20}" Appearance="Secondary"
                               Height="32" Padding="9,0" Command="{Binding ClearEStopCommand}" Margin="0,0,5,0"
                               AutomationProperties.AutomationId="ResetEStopButton" />
                    <ui:Button Content="急停 F12" Icon="{ui:SymbolIcon Warning20}" Appearance="Danger"
                               Height="32" Padding="10,0" Command="{Binding TriggerEStopCommand}"
                               AutomationProperties.AutomationId="EStopButton" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="10,8,10,0" Padding="12,7" CornerRadius="6"
                Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                BorderBrush="{DynamicResource SystemFillColorCriticalBrush}" BorderThickness="1"
                Visibility="{Binding EStopEngaged, Converter={StaticResource BooleanToVisibilityConverter}}">
            <DockPanel>
                <ui:Button DockPanel.Dock="Right" Content="确认环境安全并复位" Appearance="Secondary"
                           Command="{Binding ClearEStopCommand}" AutomationProperties.AutomationId="ResetEStopBannerButton" />
                <TextBlock Text="急停已触发 · 运动、点动、示教与回放全部锁定"
                           FontWeight="SemiBold" Foreground="{DynamicResource SystemFillColorCriticalBrush}" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
            <Grid MinWidth="1180" MinHeight="700">
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
                </Grid.LayoutTransform>

                <Grid x:Name="ControlPage" Margin="10,9,10,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210" /><ColumnDefinition Width="9" />
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="9" />
                        <ColumnDefinition Width="310" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="9" /><RowDefinition Height="165" /></Grid.RowDefinitions>
                        <Border Style="{StaticResource CockpitCardStyle}" Padding="7">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="31" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding DaemonSummary}" Style="{StaticResource MetaTextStyle}" />
                                    <TextBlock Text="六轴实时状态" Style="{StaticResource SectionHeaderTextStyle}" />
                                </DockPanel>
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Joints}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="6" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <controls:JointStatusCard Margin="0,2" Title="{Binding Name}" Subtitle="{Binding Subtitle}"
                                                Position="{Binding Position}" Minimum="{Binding Minimum}" Maximum="{Binding Maximum}"
                                                Velocity="{Binding Velocity}" IsOnline="{Binding Valid}" IsWarning="{Binding LimitWarning}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                        <Border Grid.Row="2" Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="35" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardHeaderStyle}"><DockPanel><TextBlock DockPanel.Dock="Right" Text="BASE FRAME" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="末端位姿" Style="{StaticResource SectionHeaderTextStyle}" /></DockPanel></Border>
                                <UniformGrid Grid.Row="1" Columns="2" Margin="6">
                                    <Border Style="{StaticResource MetricCellStyle}"><StackPanel><TextBlock Text="X / m" Style="{StaticResource MetricLabelStyle}" /><TextBlock Text="{Binding TcpX, StringFormat={}{0:+0.000;-0.000;0.000}}" Style="{StaticResource MetricValueStyle}" /></StackPanel></Border>
                                    <Border Style="{StaticResource MetricCellStyle}"><StackPanel><TextBlock Text="Y / m" Style="{StaticResource MetricLabelStyle}" /><TextBlock Text="{Binding TcpY, StringFormat={}{0:+0.000;-0.000;0.000}}" Style="{StaticResource MetricValueStyle}" /></StackPanel></Border>
                                    <Border Style="{StaticResource MetricCellStyle}"><StackPanel><TextBlock Text="Z / m" Style="{StaticResource MetricLabelStyle}" /><TextBlock Text="{Binding TcpZ, StringFormat={}{0:+0.000;-0.000;0.000}}" Style="{StaticResource MetricValueStyle}" /></StackPanel></Border>
                                    <Border Style="{StaticResource MetricCellStyle}"><StackPanel><TextBlock Text="状态年龄" Style="{StaticResource MetricLabelStyle}" /><TextBlock Text="{Binding StateAgeMs, StringFormat={}{0} ms}" Style="{StaticResource MetricValueStyle}" /></StackPanel></Border>
                                </UniformGrid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="9" /><RowDefinition Height="205" /></Grid.RowDefinitions>
                        <Border Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <local:CadThreeView x:Name="CadView"
                                J1="{Binding Joints[0].Position}" J2="{Binding Joints[1].Position}" J3="{Binding Joints[2].Position}"
                                J4="{Binding Joints[3].Position}" J5="{Binding Joints[4].Position}" J6="{Binding Joints[5].Position}"
                                GripperPercent="{Binding GripperPercent, Mode=OneWay}" Theme="{Binding Theme, Mode=OneWay}" />
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="37" /><RowDefinition Height="*" /><RowDefinition Height="37" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardHeaderStyle}"><DockPanel><TextBlock DockPanel.Dock="Right" Text="统一 Linux 控制面 · WPF 仅发送意图" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="运动控制" Style="{StaticResource SectionHeaderTextStyle}" /></DockPanel></Border>
                                <TabControl Grid.Row="1" Margin="8,1" Background="Transparent" BorderThickness="0">
                                    <TabItem Header="MoveJ · 关节空间">
                                        <UniformGrid Columns="6" Margin="3,4">
                                            <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="J1 / rad" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetJ1}" /></StackPanel>
                                            <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="J2 / rad" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetJ2}" /></StackPanel>
                                            <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="J3 / rad" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetJ3}" /></StackPanel>
                                            <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="J4 / rad" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetJ4}" /></StackPanel>
                                            <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="J5 / rad" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetJ5}" /></StackPanel>
                                            <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="J6 / rad" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetJ6}" /></StackPanel>
                                        </UniformGrid>
                                    </TabItem>
                                    <TabItem Header="MoveL · 笛卡尔直线">
                                        <UniformGrid Columns="6" Margin="3,4">
                                            <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="X / m" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetX}" /></StackPanel>
                                            <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="Y / m" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetY}" /></StackPanel>
                                            <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="Z / m" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetZ}" /></StackPanel>
                                            <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="Roll" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetRoll}" /></StackPanel>
                                            <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="Pitch" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetPitch}" /></StackPanel>
                                            <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="Yaw" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetYaw}" /></StackPanel>
                                        </UniformGrid>
                                    </TabItem>
                                </TabControl>
                                <Grid Grid.Row="2" Margin="10,0,10,7">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="180" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="时长" VerticalAlignment="Center" FontSize="10" /><Slider Grid.Column="1" Margin="8,0" Minimum="0.5" Maximum="10" Value="{Binding TargetDuration}" /><ProgressBar Grid.Column="2" Margin="10,0" Maximum="1" Value="{Binding ExecutionFraction}" />
                                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                                        <ui:Button Content="MoveJ" Appearance="Primary" Command="{Binding MoveJCommand}" AutomationProperties.AutomationId="MoveJButton" />
                                        <ui:Button Content="MoveL" Appearance="Secondary" Command="{Binding MoveLCommand}" Margin="5,0,0,0" AutomationProperties.AutomationId="MoveLButton" />
                                        <ui:Button Content="取消" Appearance="Transparent" Command="{Binding CancelExecutionCommand}" Margin="4,0,0,0" AutomationProperties.AutomationId="CancelExecutionButton" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="4">
                        <Grid.RowDefinitions><RowDefinition Height="142" /><RowDefinition Height="9" /><RowDefinition Height="*" /><RowDefinition Height="9" /><RowDefinition Height="145" /></Grid.RowDefinitions>
                        <Border Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="36" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardHeaderStyle}"><DockPanel><TextBlock DockPanel.Dock="Right" Text="{Binding GripperOpeningState}" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="夹爪" Style="{StaticResource SectionHeaderTextStyle}" /></DockPanel></Border>
                                <Grid Grid.Row="1" Margin="11,7"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                    <DockPanel><TextBlock DockPanel.Dock="Right" Text="{Binding GripperTorque, StringFormat={}力矩 {0:F1} N·m}" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="{Binding GripperPercent, StringFormat={}{0:F0}%}" FontFamily="Cascadia Mono, Consolas" FontSize="22" FontWeight="Bold" /></DockPanel>
                                    <ProgressBar Grid.Row="1" Height="7" Maximum="100" Value="{Binding GripperPercent}" />
                                    <UniformGrid Grid.Row="2" Columns="2" Margin="0,7,0,0">
                                        <ui:Button Content="张开" Command="{Binding GripperOpenCommand}" Appearance="Secondary" Margin="0,0,3,0" AutomationProperties.AutomationId="GripperOpenButton" />
                                        <ui:Button Content="闭合" Command="{Binding GripperCloseCommand}" Appearance="Secondary" Margin="3,0,0,0" AutomationProperties.AutomationId="GripperCloseButton" />
                                    </UniformGrid>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="36" /><RowDefinition Height="*" /><RowDefinition Height="35" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardHeaderStyle}"><DockPanel><TextBlock DockPanel.Dock="Right" Text="HOLD-TO-RUN" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="关节点动 Jog" Style="{StaticResource SectionHeaderTextStyle}" /></DockPanel></Border>
                                <UniformGrid Grid.Row="1" Columns="2" Rows="3" Margin="6,5,6,2">
                                    <controls:JogPod Margin="3" Title="J1" Subtitle="基座" Position="{Binding Joints[0].Position}" NegativeParameter="0:-1" PositiveParameter="0:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                    <controls:JogPod Margin="3" Title="J2" Subtitle="肩部" Position="{Binding Joints[1].Position}" NegativeParameter="1:-1" PositiveParameter="1:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                    <controls:JogPod Margin="3" Title="J3" Subtitle="肘部" Position="{Binding Joints[2].Position}" NegativeParameter="2:-1" PositiveParameter="2:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                    <controls:JogPod Margin="3" Title="J4" Subtitle="腕旋" Position="{Binding Joints[3].Position}" NegativeParameter="3:-1" PositiveParameter="3:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                    <controls:JogPod Margin="3" Title="J5" Subtitle="腕俯" Position="{Binding Joints[4].Position}" NegativeParameter="4:-1" PositiveParameter="4:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                    <controls:JogPod Margin="3" Title="J6" Subtitle="末端" Position="{Binding Joints[5].Position}" NegativeParameter="5:-1" PositiveParameter="5:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                </UniformGrid>
                                <DockPanel Grid.Row="2" Margin="10,0"><TextBlock DockPanel.Dock="Right" Text="长按即动 · 松开即停" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="速度" VerticalAlignment="Center" FontSize="10" /><Slider Width="130" Margin="8,0" Minimum="0.02" Maximum="0.35" Value="{Binding JogSpeed}" /><TextBlock Text="{Binding JogSpeed, StringFormat={}{0:F2}}" Style="{StaticResource MetaTextStyle}" /></DockPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="4" Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="36" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardHeaderStyle}"><DockPanel><TextBlock DockPanel.Dock="Right" Text="{Binding ControlSummary}" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="安全与控制权" Style="{StaticResource SectionHeaderTextStyle}" /></DockPanel></Border>
                                <Grid Grid.Row="1" Margin="10,7"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                    <DockPanel><TextBlock Text="控制所有者" Foreground="{DynamicResource TextFillColorTertiaryBrush}" /><TextBlock DockPanel.Dock="Right" Text="{Binding ControlHolder}" FontFamily="Cascadia Mono, Consolas" FontWeight="SemiBold" /></DockPanel>
                                    <DockPanel Grid.Row="1" Margin="0,5,0,0"><TextBlock Text="安全状态" Foreground="{DynamicResource TextFillColorTertiaryBrush}" /><TextBlock DockPanel.Dock="Right" Text="{Binding ExecutionStatus}" FontFamily="Cascadia Mono, Consolas" /></DockPanel>
                                    <UniformGrid Grid.Row="2" Columns="2" Margin="0,8,0,0">
                                        <ui:Button Content="获取控制" Icon="{ui:SymbolIcon LockClosed20}" Appearance="Primary" Command="{Binding AcquireControlCommand}" Margin="0,0,3,0" AutomationProperties.AutomationId="AcquireControlButton" />
                                        <ui:Button Content="释放" Icon="{ui:SymbolIcon LockOpen20}" Appearance="Secondary" Command="{Binding ReleaseControlCommand}" Margin="3,0,0,0" AutomationProperties.AutomationId="ReleaseControlButton" />
                                    </UniformGrid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="DataPage" Visibility="Collapsed" Margin="10,9,10,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="1.28*" /><ColumnDefinition Width="9" /><ColumnDefinition Width="0.72*" /></Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="9" /><RowDefinition Height="190" /></Grid.RowDefinitions>
                        <Border Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="37" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardHeaderStyle}"><DockPanel><TextBlock DockPanel.Dock="Right" Text="RGB8 + Z16 · 640×480 @ 30 FPS" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="Intel RealSense D405" Style="{StaticResource SectionHeaderTextStyle}" /></DockPanel></Border>
                                <Grid Grid.Row="1" Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Background="#FF101418" CornerRadius="6" ClipToBounds="True" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1"><Grid><Image x:Name="ColorCameraImage" Stretch="Uniform" AutomationProperties.AutomationId="ColorCameraImage" /><Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="7" Padding="6,2" CornerRadius="3" Background="#AA000000"><TextBlock Text="COLOR · RGB8" Foreground="White" FontFamily="Cascadia Mono, Consolas" FontSize="10" /></Border></Grid></Border>
                                    <Border Grid.Column="2" Background="#FF101418" CornerRadius="6" ClipToBounds="True" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1"><Grid><Image x:Name="DepthCameraImage" Stretch="Uniform" AutomationProperties.AutomationId="DepthCameraImage" /><Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="7" Padding="6,2" CornerRadius="3" Background="#AA000000"><TextBlock Text="DEPTH · Z16" Foreground="White" FontFamily="Cascadia Mono, Consolas" FontSize="10" /></Border></Grid></Border>
                                </Grid>
                            </Grid>
                        </Border>
                        <Border Grid.Row="2" Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="37" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardHeaderStyle}"><DockPanel><TextBlock DockPanel.Dock="Right" Text="机械臂状态 + RGB + 深度 · 同一 Linux 时钟" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="拖动示教与同步录制" Style="{StaticResource SectionHeaderTextStyle}" /></DockPanel></Border>
                                <Grid Grid.Row="1" Margin="10"><Grid.ColumnDefinitions><ColumnDefinition Width="1.2*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="1*" /></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="操作顺序" Style="{StaticResource MetricLabelStyle}" /><TextBlock Text="1. 获取控制权  2. 启动拖动示教  3. 开始同步录制" Margin="0,4,0,8" FontSize="11" /><StackPanel Orientation="Horizontal"><ui:Button Content="开始拖动示教" Appearance="Primary" Command="{Binding StartTeachCommand}" AutomationProperties.AutomationId="StartTeachButton" /><ui:Button Content="停止示教" Appearance="Secondary" Command="{Binding StopTeachCommand}" Margin="6,0,0,0" AutomationProperties.AutomationId="StopTeachButton" /></StackPanel><TextBlock Text="{Binding TeachStatus}" Margin="0,8,0,0" Style="{StaticResource MetaTextStyle}" /></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="录制状态" Style="{StaticResource MetricLabelStyle}" /><TextBlock Text="{Binding RecordingPath}" TextTrimming="CharacterEllipsis" Margin="0,4,0,8" FontFamily="Cascadia Mono, Consolas" FontSize="10" /><StackPanel Orientation="Horizontal"><ui:Button Content="开始录制" Appearance="Primary" Command="{Binding StartTeachRecordingCommand}" AutomationProperties.AutomationId="StartTeachRecordingButton" /><ui:Button Content="停止并保存" Appearance="Secondary" Command="{Binding StopTeachRecordingCommand}" Margin="6,0,0,0" AutomationProperties.AutomationId="StopTeachRecordingButton" /></StackPanel></StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions><RowDefinition Height="122" /><RowDefinition Height="9" /><RowDefinition Height="*" /><RowDefinition Height="9" /><RowDefinition Height="190" /></Grid.RowDefinitions>
                        <Border Style="{StaticResource CockpitCardStyle}" ClipToBounds="True"><Grid><Grid.RowDefinitions><RowDefinition Height="36" /><RowDefinition Height="*" /></Grid.RowDefinitions><Border Style="{StaticResource CardHeaderStyle}"><DockPanel><TextBlock DockPanel.Dock="Right" Text="{Binding CameraAvailable}" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="设备信息" Style="{StaticResource SectionHeaderTextStyle}" /></DockPanel></Border><Grid Grid.Row="1" Margin="10,7"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions><DockPanel><TextBlock Text="D405" FontWeight="SemiBold" /><TextBlock DockPanel.Dock="Right" Text="{Binding CameraSummary}" Style="{StaticResource MetaTextStyle}" /></DockPanel><StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0"><ui:Button Content="一键引导" Icon="{ui:SymbolIcon UsbPlug20}" Appearance="Primary" Click="RunEnvironment_Click" AutomationProperties.AutomationId="EnvironmentGuideButton" /><ui:Button Content="只读检测" Appearance="Secondary" Command="{Binding ProbeEnvironmentCommand}" Margin="6,0,0,0" AutomationProperties.AutomationId="ProbeEnvironmentButton" /></StackPanel></Grid></Grid></Border>

                        <Border Grid.Row="2" Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <TabControl Background="Transparent" BorderThickness="0">
                                <TabItem Header="轨迹库">
                                    <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="37" /></Grid.RowDefinitions>
                                        <ListBox ItemsSource="{Binding TeachRecordings}" SelectedItem="{Binding SelectedTeachRecording}" BorderThickness="0" Background="Transparent">
                                            <ListBox.ItemTemplate><DataTemplate><Border Margin="0,2" Padding="8,6" Style="{StaticResource CockpitSubtlePanelStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11" /><TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis" Style="{StaticResource MetaTextStyle}" /></StackPanel><StackPanel Grid.Column="1" HorizontalAlignment="Right"><TextBlock Text="{Binding Summary}" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="{Binding RecordedAt, StringFormat={}{0:MM-dd HH:mm}}" HorizontalAlignment="Right" Style="{StaticResource MetaTextStyle}" /></StackPanel></Grid></Border></DataTemplate></ListBox.ItemTemplate>
                                        </ListBox>
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"><ui:Button Content="刷新" Appearance="Transparent" Command="{Binding RefreshTeachRecordingsCommand}" /><ui:Button Content="POS-VEL 回放" Appearance="Primary" Command="{Binding PlayTeachRecordingCommand}" Margin="6,0,0,0" AutomationProperties.AutomationId="PlayTeachRecordingButton" /><ui:Button Content="取消" Appearance="Secondary" Command="{Binding CancelExecutionCommand}" Margin="6,0,0,0" /></StackPanel>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="系统日志">
                                    <ListBox ItemsSource="{Binding Logs}" BorderThickness="0" Background="Transparent" ItemContainerStyle="{StaticResource LogListItemStyle}"><ListBox.ItemTemplate><DataTemplate><Grid Margin="8,3"><Grid.ColumnDefinitions><ColumnDefinition Width="80" /><ColumnDefinition Width="65" /><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Style="{StaticResource MetaTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding Level}" FontWeight="Bold" FontSize="10" /><TextBlock Grid.Column="2" Text="{Binding Source}" Style="{StaticResource MetaTextStyle}" /><TextBlock Grid.Column="3" Text="{Binding Message}" TextTrimming="CharacterEllipsis" FontSize="10" /></Grid></DataTemplate></ListBox.ItemTemplate></ListBox>
                                </TabItem>
                                <TabItem Header="环境引导">
                                    <ListView ItemsSource="{Binding EnvironmentSteps}" BorderThickness="0" Background="Transparent"><ListView.View><GridView><GridViewColumn Header="步骤" Width="120" DisplayMemberBinding="{Binding Name}" /><GridViewColumn Header="结果" Width="60" DisplayMemberBinding="{Binding Success}" /><GridViewColumn Header="说明" Width="270" DisplayMemberBinding="{Binding Detail}" /></GridView></ListView.View></ListView>
                                </TabItem>
                            </TabControl>
                        </Border>

                        <Border Grid.Row="4" Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="36" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardHeaderStyle}"><DockPanel><TextBlock DockPanel.Dock="Right" Text="{Binding DatasetStatus}" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="LeRobotDataset v3 导出" Style="{StaticResource SectionHeaderTextStyle}" /></DockPanel></Border>
                                <Grid Grid.Row="1" Margin="10"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="34" /></Grid.RowDefinitions>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="78" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="Repo ID" VerticalAlignment="Center" FontSize="10" /><TextBox Grid.Column="1" Text="{Binding DatasetRepoId}" /></Grid>
                                    <Grid Grid.Row="1" Margin="0,5,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="78" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="Task" VerticalAlignment="Center" FontSize="10" /><TextBox Grid.Column="1" Text="{Binding DatasetTask}" /></Grid>
                                    <ProgressBar Grid.Row="2" Height="7" Margin="0,8,0,0" Maximum="100" Value="{Binding DatasetProgress}" />
                                    <TextBlock Grid.Row="3" Text="{Binding DatasetResult}" TextTrimming="CharacterEllipsis" Margin="0,6,0,0" Style="{StaticResource MetaTextStyle}" />
                                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"><ui:Button Content="取消导出" Appearance="Transparent" Command="{Binding CancelDatasetExportCommand}" /><ui:Button Content="导出数据集" Appearance="Primary" Command="{Binding ExportDatasetCommand}" Margin="6,0,0,0" AutomationProperties.AutomationId="ExportDatasetButton" /></StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="4" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <DockPanel Margin="10,0">
                <TextBlock DockPanel.Dock="Right" Text="Ctrl + / − 缩放 · Ctrl+0 重置 · F12 急停 · Esc 取消" Style="{StaticResource MetaTextStyle}" />
                <Ellipse Width="6" Height="6" Fill="{DynamicResource SystemFillColorSuccessBrush}" Margin="0,0,7,0" />
                <TextBlock Text="Linux control plane" FontFamily="Cascadia Mono, Consolas" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="  ·  Exact CAD / armd / camerad" Margin="6,0,0,0" Style="{StaticResource MetaTextStyle}" />
            </DockPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
