<Window x:Class="Panthera.Terminal.App.SshDeploymentProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="SSH 部署"
        Width="620" Height="570" MinWidth="620" MinHeight="570"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" ShowInTaskbar="False"
        FontFamily="Segoe UI Variable Text, Microsoft YaHei UI, Segoe UI"
        Background="Transparent"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        AutomationProperties.AutomationId="SshDeploymentProgressDialog">
    <Window.Resources>
        <Style x:Key="ChromelessCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="14"
            Background="{DynamicResource ApplicationBackgroundBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="22" ShadowDepth="4"
                              Direction="270" Opacity="0.42" RenderingBias="Quality" />
        </Border.Effect>
        <Grid Margin="22,12,22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="SSH 部署" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock x:Name="TargetText" Margin="0,1,0,0" FontSize="11.5"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <Button x:Name="CloseButton" Grid.Column="1" Content="×" Width="32" Height="32"
                        FontSize="19" Cursor="Hand" Click="CloseButton_Click"
                        Style="{StaticResource ChromelessCloseButtonStyle}"
                        AutomationProperties.AutomationId="CloseSshDeploymentProgressButton" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,12,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="HeadlineText" Text="准备开始…" FontSize="14" FontWeight="SemiBold" />
                <TextBlock x:Name="ProgressCountText" Grid.Column="1" Text="0 / 6" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ProgressBar x:Name="OverallProgress" Grid.ColumnSpan="2" Height="4" Margin="0,27,0,0"
                             Minimum="0" Maximum="6" Value="0" />
            </Grid>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Steps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,8" Padding="12,10" CornerRadius="7"
                                    Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Width="26" Height="26" CornerRadius="13" VerticalAlignment="Top">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding State}" Value="Running">
                                                        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="Succeeded">
                                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="Failed">
                                                        <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="14" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="·" />
                                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding State}" Value="Running">
                                                            <Setter Property="Text" Value="↻" />
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="Succeeded">
                                                            <Setter Property="Text" Value="✓" />
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="Failed">
                                                            <Setter Property="Text" Value="×" />
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="13.5"
                                               FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="11.5"
                                               VerticalAlignment="Center" Margin="10,0,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,5,0,0">
                                        <TextBlock Text="{Binding Detail}" FontSize="11.5" TextWrapping="Wrap"
                                                   MaxHeight="38" ToolTip="{Binding Detail}"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <ProgressBar Height="2" Margin="0,7,0,0" IsIndeterminate="True">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding State}" Value="Running">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid Grid.Row="3" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="SummaryText" MaxWidth="390" Text="正在准备远程部署…"
                           TextWrapping="Wrap" VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ui:Button x:Name="ActionButton" Grid.Column="1" Content="执行中…"
                           Width="126" Height="36" IsEnabled="False" Appearance="Primary"
                           Click="ActionButton_Click"
                           AutomationProperties.AutomationId="FinishSshDeploymentButton" />
            </Grid>
        </Grid>
    </Border>
</Window>
