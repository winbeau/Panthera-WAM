<UserControl x:Class="Panthera.Terminal.Controls.JogPod"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Panthera.Terminal.Controls"
             MinWidth="122" MinHeight="74">
    <Border Padding="8,5" Style="{DynamicResource CockpitSubtlePanelStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontFamily="Cascadia Mono, Consolas" FontSize="13" FontWeight="Bold" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding Position, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat={}{0:F3}}"
                               FontFamily="Cascadia Mono, Consolas" FontSize="12.5" FontWeight="Bold" />
                    <TextBlock Text=" rad" FontFamily="Cascadia Mono, Consolas" FontSize="8"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                </StackPanel>
            </Grid>
            <TextBlock Grid.Row="1" Margin="0,0,0,3"
                       Text="{Binding Subtitle, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="9.5" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            <UniformGrid Grid.Row="2" Columns="2">
                <controls:JogButton Margin="0,0,3,0" Content="−"
                                    Style="{DynamicResource JogRockerButtonStyle}"
                                    ToolTip="按住鼠标、空格或回车执行负向点动，松开即停"
                                    AutomationProperties.AutomationId="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat={}{0}NegativeJogButton}"
                                    AutomationProperties.Name="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat={}{0} 负向点动}"
                                    AutomationProperties.HelpText="按住空格或回车持续点动，松开立即停止"
                                    JogParameter="{Binding NegativeParameter, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    PressCommand="{Binding PressCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    ReleaseCommand="{Binding ReleaseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                <controls:JogButton Margin="3,0,0,0" Content="+"
                                    Style="{DynamicResource JogRockerButtonStyle}"
                                    ToolTip="按住鼠标、空格或回车执行正向点动，松开即停"
                                    AutomationProperties.AutomationId="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat={}{0}PositiveJogButton}"
                                    AutomationProperties.Name="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat={}{0} 正向点动}"
                                    AutomationProperties.HelpText="按住空格或回车持续点动，松开立即停止"
                                    JogParameter="{Binding PositiveParameter, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    PressCommand="{Binding PressCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    ReleaseCommand="{Binding ReleaseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </UniformGrid>
        </Grid>
    </Border>
</UserControl>
