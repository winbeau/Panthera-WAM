<UserControl x:Class="Panthera.Terminal.App.CadThreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             MinWidth="620" MinHeight="400"
             Focusable="False" KeyboardNavigation.IsTabStop="False">
    <Grid ClipToBounds="True" Background="{DynamicResource ControlFillColorTertiaryBrush}">
        <wv2:WebView2 x:Name="Browser" Focusable="False" KeyboardNavigation.IsTabStop="False"
                      IsHitTestVisible="False" />

        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="9"
                Padding="5" CornerRadius="6"
                Background="{DynamicResource AcrylicBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="StylePicker" Width="100" Height="28" SelectionChanged="StylePicker_SelectionChanged"
                          AutomationProperties.AutomationId="CadStyleSelector">
                    <ComboBoxItem Content="工程草图" Tag="sketch" IsSelected="True" />
                    <ComboBoxItem Content="实体" Tag="solid" />
                    <ComboBoxItem Content="材质" Tag="material" />
                    <ComboBoxItem Content="渲染" Tag="rendered" />
                    <ComboBoxItem Content="蓝图" Tag="blueprint" />
                    <ComboBoxItem Content="X-Ray" Tag="xray" />
                    <ComboBoxItem Content="线框" Tag="wireframe" />
                </ComboBox>
                <ComboBox x:Name="CameraPicker" Width="96" Height="28" Margin="5,0,0,0"
                          SelectionChanged="CameraPicker_SelectionChanged"
                          AutomationProperties.AutomationId="CadCameraSelector">
                    <ComboBoxItem Content="固定基座" Tag="fixed-base" IsSelected="True" />
                    <ComboBoxItem Content="跟随运动" Tag="follow" />
                </ComboBox>
            </StackPanel>
        </Border>

        <Border x:Name="LoadingOverlay" HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="12,8" CornerRadius="7"
                Background="{DynamicResource AcrylicBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <ProgressBar Width="82" Height="4" IsIndeterminate="True" VerticalAlignment="Center" />
                <TextBlock x:Name="LoadingText" Text="正在初始化精确 CAD…" Margin="10,0,0,0"
                           FontSize="11" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
