<ui:FluentWindow x:Class="Panthera.Terminal.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Panthera.Terminal.Controls;assembly=Panthera.Terminal.Controls"
        xmlns:local="clr-namespace:Panthera.Terminal.App"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Panthera-HT 控制终端"
        Width="1600" Height="960" MinWidth="1180" MinHeight="760"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="None" WindowCornerPreference="Round"
        FontFamily="Segoe UI Variable Text, Microsoft YaHei UI, Segoe UI" FontSize="13.5"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        WindowStartupLocation="CenterScreen" UseLayoutRounding="True"
        SnapsToDevicePixels="True" KeyboardNavigation.TabNavigation="Cycle">
    <ui:FluentWindow.Resources>
        <Style x:Key="CardHeaderStyle" TargetType="Border">
            <Setter Property="Padding" Value="11,7" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style x:Key="MetricCellStyle" TargetType="Border" BasedOn="{StaticResource CockpitSubtlePanelStyle}">
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="3" />
        </Style>
        <Style x:Key="InputStackStyle" TargetType="StackPanel">
            <Setter Property="Margin" Value="4,1,4,2" />
        </Style>
        <Style x:Key="StatusDotStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="7" />
            <Setter Property="Height" Value="7" />
            <Setter Property="Fill" Value="{DynamicResource TextFillColorTertiaryBrush}" />
        </Style>
        <Style x:Key="MainTabStyle" TargetType="RadioButton">
            <Setter Property="MinWidth" Value="142" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder" Padding="14,0" CornerRadius="6"
                                Background="Transparent" BorderBrush="Transparent" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CancelExecutionCommand}" />
        <KeyBinding Key="OemMinus" Modifiers="Control" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Key="Subtract" Modifiers="Control" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Key="OemPlus" Modifiers="Control" Command="{Binding ZoomInCommand}" />
        <KeyBinding Key="Add" Modifiers="Control" Command="{Binding ZoomInCommand}" />
        <KeyBinding Key="D0" Modifiers="Control" Command="{Binding ResetZoomCommand}" />
    </ui:FluentWindow.InputBindings>

    <Grid Background="{DynamicResource ApplicationBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="52" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="27" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Panthera WAM v2"
                     Icon="{ui:ImageIcon 'pack://application:,,,/Assets/Brand/panthera-terminal-titlebar.png'}">
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="LINUX UNIFIED" Margin="0,0,10,0" FontFamily="Cascadia Mono, Consolas"
                               Foreground="{DynamicResource SystemFillColorSuccessBrush}" FontSize="11" />
                    <TextBlock Text="WPF VISUAL TERMINAL" Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="11" />
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <Border Grid.Row="1" Background="{DynamicResource LayerFillColorAltBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton x:Name="ControlTabButton" Content="控制与三视图" GroupName="MainTabs"
                                 Style="{StaticResource MainTabStyle}" IsChecked="True" Tag="Control"
                                 Checked="MainTab_Checked" AutomationProperties.AutomationId="ControlTabButton" />
                    <RadioButton x:Name="DataTabButton" Content="D405 与示教录制" GroupName="MainTabs"
                                 Style="{StaticResource MainTabStyle}" Tag="Data"
                                 Checked="MainTab_Checked" AutomationProperties.AutomationId="DataTabButton" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Right" Margin="2,0,4,0">
                    <Border Margin="0,0,4,0" Style="{StaticResource CockpitBadgeStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Margin="0,0,6,0">
                                <Ellipse.Style><Style TargetType="Ellipse" BasedOn="{StaticResource StatusDotStyle}"><Style.Triggers><DataTrigger Binding="{Binding IsConnected}" Value="True"><Setter Property="Fill" Value="{DynamicResource SystemFillColorSuccessBrush}" /></DataTrigger></Style.Triggers></Style></Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="ARM " FontSize="12.5" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ConnectionLabel}" FontFamily="Cascadia Mono, Consolas" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,4,0" Style="{StaticResource CockpitBadgeStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Margin="0,0,6,0" Style="{StaticResource StatusDotStyle}" Fill="{DynamicResource SystemFillColorSuccessBrush}" />
                            <TextBlock Text="D405 " FontSize="12.5" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding CameraSummary}" MaxWidth="100" TextTrimming="CharacterEllipsis"
                                       FontFamily="Cascadia Mono, Consolas" FontSize="12" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,4,0" Style="{StaticResource CockpitBadgeStyle}">
                        <TextBlock Text="{Binding LiveSummary}" FontFamily="Cascadia Mono, Consolas" FontSize="12" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Content="−" Width="34" Height="34" Appearance="Secondary" Command="{Binding ZoomOutCommand}" ToolTip="Ctrl+-" />
                    <TextBlock Text="{Binding UiScaleLabel}" Width="45" HorizontalAlignment="Center" TextAlignment="Center"
                               VerticalAlignment="Center" FontFamily="Cascadia Mono, Consolas" FontSize="12" />
                    <ui:Button Content="+" Width="34" Height="34" Appearance="Secondary" Command="{Binding ZoomInCommand}" ToolTip="Ctrl++" />
                    <ui:Button Content="复位" Icon="{ui:SymbolIcon ArrowSync20}" Height="36" Padding="10,1"
                               Appearance="Secondary" Command="{Binding ResetArmCommand}" Margin="3,0,4,0"
                               ToolTip="移动到安全复位姿态 J=[0.0, 0.6, 0.6, 0.0, 0.0, 0.0]"
                               AutomationProperties.AutomationId="ResetArmButton" />
                    <ui:Button Content="{Binding DemoActionLabel}" Height="36" Padding="10,1"
                               Appearance="Secondary" Command="{Binding ToggleDemoSequenceCommand}" Margin="0,0,4,0"
                               ToolTip="循环执行安全位与两组官方示例姿态；再次点击在当前段完成后停止"
                               AutomationProperties.AutomationId="DemoSequenceButton" />
                    <ComboBox Width="92" Height="38" Padding="9,0" Margin="0,0,5,0" SelectedValuePath="Content"
                              FontFamily="Segoe UI, Microsoft YaHei UI" FontSize="13.5"
                              VerticalContentAlignment="Center" HorizontalContentAlignment="Stretch"
                              SelectedValue="{Binding Theme}" SelectionChanged="Theme_SelectionChanged"
                              AutomationProperties.AutomationId="ThemeSelector">
                        <ComboBoxItem Content="System" /><ComboBoxItem Content="Light" /><ComboBoxItem Content="Dark" />
                    </ComboBox>
                    <ui:Button Content="解除急停" Icon="{ui:SymbolIcon ArrowSync20}" Appearance="Secondary"
                               Height="36" Padding="10,1" FontSize="13" Command="{Binding ClearEStopCommand}" Margin="0,0,5,0"
                               AutomationProperties.AutomationId="ResetEStopButton" />
                    <ui:Button Content="急停 F12" Icon="{ui:SymbolIcon Warning20}" Appearance="Danger"
                               Height="36" Padding="11,1" FontSize="13" Command="{Binding TriggerEStopCommand}"
                               AutomationProperties.AutomationId="EStopButton" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="10,8,10,0" Padding="12,7" CornerRadius="6"
                Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                BorderBrush="{DynamicResource SystemFillColorCriticalBrush}" BorderThickness="1"
                Visibility="{Binding EStopEngaged, Converter={StaticResource BooleanToVisibilityConverter}}">
            <DockPanel>
                <ui:Button DockPanel.Dock="Right" Content="确认环境安全并复位" Appearance="Secondary"
                           Command="{Binding ClearEStopCommand}" AutomationProperties.AutomationId="ResetEStopBannerButton" />
                <TextBlock Text="急停已触发 · 运动、点动、示教与回放全部锁定"
                           FontWeight="SemiBold" Foreground="{DynamicResource SystemFillColorCriticalBrush}" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="3" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
            <Grid MinWidth="1120" MinHeight="630">
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
                </Grid.LayoutTransform>

                <Grid x:Name="ControlPage" Margin="10,7,10,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="8" />
                        <ColumnDefinition Width="296" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="7" /><RowDefinition Height="212" /></Grid.RowDefinitions>
                        <Border Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <local:CadThreeView x:Name="CadView"
                                J1="{Binding Joints[0].Position}" J2="{Binding Joints[1].Position}" J3="{Binding Joints[2].Position}"
                                J4="{Binding Joints[3].Position}" J5="{Binding Joints[4].Position}" J6="{Binding Joints[5].Position}"
                                TcpX="{Binding TcpX}" TcpY="{Binding TcpY}" TcpZ="{Binding TcpZ}"
                                GripperPercent="{Binding GripperPercent, Mode=OneWay}" Theme="{Binding Theme, Mode=OneWay}" />
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="36" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardHeaderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="运动控制" Style="{StaticResource SectionHeaderTextStyle}" />
                                        <ProgressBar Grid.Column="1" Width="180" Height="4" Margin="18,0" HorizontalAlignment="Right" VerticalAlignment="Center" Maximum="1" Value="{Binding ExecutionFraction}" />
                                        <TextBlock Grid.Column="2" Text="统一 Linux 控制面 · WPF 仅发送意图" Style="{StaticResource MetaTextStyle}" />
                                    </Grid>
                                </Border>
                                <Grid Grid.Row="1" Margin="10,5,10,7">
                                    <Grid.Resources>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                            <Setter Property="Height" Value="34" />
                                            <Setter Property="Padding" Value="8,1" />
                                            <Setter Property="FontSize" Value="13.5" />
                                            <Setter Property="VerticalContentAlignment" Value="Center" />
                                        </Style>
                                    </Grid.Resources>
                                    <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="42" /></Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="13" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>

                                    <UniformGrid Grid.Column="0" Columns="3" Rows="2" Margin="0,0,5,0">
                                        <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="J1 / rad" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetJ1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="MoveJTargetJ1" /></StackPanel>
                                        <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="J2 / rad" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetJ2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="MoveJTargetJ2" /></StackPanel>
                                        <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="J3 / rad" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetJ3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="MoveJTargetJ3" /></StackPanel>
                                        <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="J4 / rad" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetJ4, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="MoveJTargetJ4" /></StackPanel>
                                        <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="J5 / rad" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetJ5, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="MoveJTargetJ5" /></StackPanel>
                                        <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="J6 / rad" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetJ6, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="MoveJTargetJ6" /></StackPanel>
                                    </UniformGrid>

                                    <Border Grid.Column="1" Grid.RowSpan="2" Width="1" Margin="6,0" HorizontalAlignment="Center" Background="{DynamicResource DividerStrokeColorDefaultBrush}" />

                                    <UniformGrid Grid.Column="2" Columns="3" Rows="2" Margin="5,0,0,0">
                                        <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="X / m" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="MoveLTargetX" /></StackPanel>
                                        <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="Y / m" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="MoveLTargetY" /></StackPanel>
                                        <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="Z / m" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="MoveLTargetZ" /></StackPanel>
                                        <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="Roll / rad" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetRoll, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="MoveLTargetRoll" /></StackPanel>
                                        <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="Pitch / rad" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetPitch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="MoveLTargetPitch" /></StackPanel>
                                        <StackPanel Style="{StaticResource InputStackStyle}"><TextBlock Text="Yaw / rad" Style="{StaticResource MetricLabelStyle}" /><TextBox Text="{Binding TargetYaw, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AutomationProperties.AutomationId="MoveLTargetYaw" /></StackPanel>
                                    </UniformGrid>

                                    <Grid Grid.Row="1" Grid.Column="0" Margin="4,2,8,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="150" /><ColumnDefinition Width="58" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="时长" FontSize="12.5" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Margin="8,0" Minimum="0.5" Maximum="10" Value="{Binding TargetMoveJDuration}" Style="{StaticResource MotionSliderStyle}" AutomationProperties.AutomationId="MoveJDurationSlider" />
                                        <TextBlock Grid.Column="2" Text="{Binding TargetMoveJDuration, StringFormat={}{0:F1} s}" Style="{StaticResource MetaTextStyle}" HorizontalAlignment="Left" />
                                        <TextBlock Grid.Column="3" Text="关节空间" Margin="0,0,10,0" HorizontalAlignment="Right" Style="{StaticResource MetaTextStyle}" />
                                        <ui:Button Grid.Column="4" Content="MoveJ" Height="38" Padding="12,0" FontSize="13" VerticalContentAlignment="Center" Appearance="Primary" Command="{Binding MoveJCommand}" AutomationProperties.AutomationId="MoveJButton" />
                                        <ui:Button Grid.Column="5" Content="取消" Height="38" Padding="11,0" FontSize="13" VerticalContentAlignment="Center" Appearance="Transparent" Command="{Binding CancelExecutionCommand}" Margin="5,0,0,0" AutomationProperties.AutomationId="CancelExecutionButton" />
                                    </Grid>

                                    <Grid Grid.Row="1" Grid.Column="2" Margin="8,2,4,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="150" /><ColumnDefinition Width="58" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="时长" FontSize="12.5" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Margin="8,0" Minimum="0.5" Maximum="10" Value="{Binding TargetMoveLDuration}" Style="{StaticResource MotionSliderStyle}" AutomationProperties.AutomationId="MoveLDurationSlider" />
                                        <TextBlock Grid.Column="2" Text="{Binding TargetMoveLDuration, StringFormat={}{0:F1} s}" Style="{StaticResource MetaTextStyle}" HorizontalAlignment="Left" />
                                        <CheckBox Grid.Column="3" Content="保持当前姿态" Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  IsChecked="{Binding PreserveOrientation, Mode=TwoWay}"
                                                  ToolTip="勾选时仅使用 X/Y/Z，Roll/Pitch/Yaw 不下发；取消勾选后六维目标全部生效。"
                                                  AutomationProperties.AutomationId="MoveLPreserveOrientationCheckBox" />
                                        <ui:Button Grid.Column="4" Content="MoveL" Height="38" Padding="12,0" FontSize="13" VerticalContentAlignment="Center" Appearance="Primary" Command="{Binding MoveLCommand}" AutomationProperties.AutomationId="MoveLButton" />
                                        <ui:Button Grid.Column="5" Content="取消" Height="38" Padding="11,0" FontSize="13" VerticalContentAlignment="Center" Appearance="Transparent" Command="{Binding CancelExecutionCommand}" Margin="5,0,0,0" AutomationProperties.AutomationId="CancelMoveLExecutionButton" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions><RowDefinition Height="126" /><RowDefinition Height="7" /><RowDefinition Height="*" /><RowDefinition Height="7" /><RowDefinition Height="142" /></Grid.RowDefinitions>
                        <Border Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="34" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardHeaderStyle}"><DockPanel><TextBlock DockPanel.Dock="Right" Text="{Binding GripperOpeningState}" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="夹爪" Style="{StaticResource SectionHeaderTextStyle}" /></DockPanel></Border>
                                <Grid Grid.Row="1" Margin="10,5"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                    <DockPanel><TextBlock DockPanel.Dock="Right" Text="{Binding GripperTorque, StringFormat={}力矩 {0:F1} N·m}" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="{Binding GripperPercent, StringFormat={}{0:F0}%}" FontFamily="Cascadia Mono, Consolas" FontSize="22" FontWeight="Bold" /></DockPanel>
                                    <ProgressBar Grid.Row="1" Height="6" Maximum="100" Value="{Binding GripperPercent, Mode=OneWay}" />
                                    <UniformGrid Grid.Row="2" Columns="2" Margin="0,5,0,0">
                                        <ui:Button Content="张开" Command="{Binding GripperOpenCommand}" Appearance="Secondary" Margin="0,0,3,0" AutomationProperties.AutomationId="GripperOpenButton" />
                                        <ui:Button Content="闭合" Command="{Binding GripperCloseCommand}" Appearance="Secondary" Margin="3,0,0,0" AutomationProperties.AutomationId="GripperCloseButton" />
                                    </UniformGrid>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="34" /><RowDefinition Height="*" /><RowDefinition Height="34" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardHeaderStyle}"><DockPanel><TextBlock DockPanel.Dock="Right" Text="HOLD-TO-RUN" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="关节点动 Jog" Style="{StaticResource SectionHeaderTextStyle}" /></DockPanel></Border>
                                <UniformGrid Grid.Row="1" Columns="1" Rows="6" Margin="6,4,6,2">
                                    <controls:JogPod Margin="0,2" Title="J1" Subtitle="基座" Position="{Binding Joints[0].Position}" Minimum="{Binding Joints[0].Minimum}" Maximum="{Binding Joints[0].Maximum}" NegativeParameter="0:-1" PositiveParameter="0:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                    <controls:JogPod Margin="0,2" Title="J2" Subtitle="肩部" Position="{Binding Joints[1].Position}" Minimum="{Binding Joints[1].Minimum}" Maximum="{Binding Joints[1].Maximum}" NegativeParameter="1:-1" PositiveParameter="1:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                    <controls:JogPod Margin="0,2" Title="J3" Subtitle="肘部" Position="{Binding Joints[2].Position}" Minimum="{Binding Joints[2].Minimum}" Maximum="{Binding Joints[2].Maximum}" NegativeParameter="2:-1" PositiveParameter="2:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                    <controls:JogPod Margin="0,2" Title="J4" Subtitle="腕旋" Position="{Binding Joints[3].Position}" Minimum="{Binding Joints[3].Minimum}" Maximum="{Binding Joints[3].Maximum}" NegativeParameter="3:-1" PositiveParameter="3:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                    <controls:JogPod Margin="0,2" Title="J5" Subtitle="腕俯" Position="{Binding Joints[4].Position}" Minimum="{Binding Joints[4].Minimum}" Maximum="{Binding Joints[4].Maximum}" NegativeParameter="4:-1" PositiveParameter="4:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                    <controls:JogPod Margin="0,2" Title="J6" Subtitle="末端" Position="{Binding Joints[5].Position}" Minimum="{Binding Joints[5].Minimum}" Maximum="{Binding Joints[5].Maximum}" NegativeParameter="5:-1" PositiveParameter="5:1" PressCommand="{Binding StartJogCommand}" ReleaseCommand="{Binding StopJogCommand}" />
                                </UniformGrid>
                                <Grid Grid.Row="2" Margin="10,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="126" /><ColumnDefinition Width="46" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="速度" VerticalAlignment="Center" FontSize="12.5" />
                                    <Slider Grid.Column="1" Margin="8,0" Minimum="0.02" Maximum="0.35" Value="{Binding JogSpeed}" Style="{StaticResource MotionSliderStyle}" AutomationProperties.AutomationId="JogSpeedSlider" />
                                    <TextBlock Grid.Column="2" Text="{Binding JogSpeed, StringFormat={}{0:F2}}" Style="{StaticResource MetaTextStyle}" HorizontalAlignment="Left" />
                                    <TextBlock Grid.Column="4" Text="松开即停" Style="{StaticResource MetaTextStyle}" />
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="4" Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="34" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardHeaderStyle}"><DockPanel><TextBlock DockPanel.Dock="Right" Text="{Binding ControlSummary}" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="安全与控制权" Style="{StaticResource SectionHeaderTextStyle}" /></DockPanel></Border>
                                <Grid Grid.Row="1" Margin="10,6,10,8"><Grid.RowDefinitions><RowDefinition Height="23" /><RowDefinition Height="23" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="控制所有者" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        <Border Grid.Column="1" HorizontalAlignment="Right" Padding="7,2" CornerRadius="4" Background="{DynamicResource ControlFillColorTertiaryBrush}">
                                            <TextBlock Text="{Binding ControlHolder}" FontFamily="Microsoft YaHei UI, Segoe UI" FontSize="12.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="安全状态" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        <Border Grid.Column="1" HorizontalAlignment="Right" Padding="7,2" CornerRadius="4" Background="{DynamicResource ControlFillColorTertiaryBrush}">
                                            <TextBlock Text="{Binding ExecutionStatus}" FontFamily="Microsoft YaHei UI, Segoe UI" FontSize="12.5" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                    <UniformGrid Grid.Row="2" Columns="2" Margin="0,7,0,0" VerticalAlignment="Bottom">
                                        <ui:Button Content="获取控制" Height="38" Padding="10,0" FontSize="13" VerticalContentAlignment="Center" Icon="{ui:SymbolIcon LockClosed20}" Appearance="Primary" Command="{Binding AcquireControlCommand}" Margin="0,0,3,0" AutomationProperties.AutomationId="AcquireControlButton" />
                                        <ui:Button Content="释放" Height="38" Padding="10,0" FontSize="13" VerticalContentAlignment="Center" Icon="{ui:SymbolIcon LockOpen20}" Appearance="Secondary" Command="{Binding ReleaseControlCommand}" Margin="3,0,0,0" AutomationProperties.AutomationId="ReleaseControlButton" />
                                    </UniformGrid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="DataPage" Visibility="Collapsed" Margin="10,9,10,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="1.28*" /><ColumnDefinition Width="9" /><ColumnDefinition Width="0.72*" /></Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="9" /><RowDefinition Height="235" /></Grid.RowDefinitions>
                        <Border Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="37" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardHeaderStyle}"><DockPanel><TextBlock DockPanel.Dock="Right" Text="RGB8 + Z16 · 640×480 @ 30 FPS" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="Intel RealSense D405" Style="{StaticResource SectionHeaderTextStyle}" /></DockPanel></Border>
                                <Grid Grid.Row="1" Margin="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <Border Background="#FF101418" CornerRadius="6" ClipToBounds="True" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1"><Grid><Image x:Name="ColorCameraImage" Stretch="Uniform" AutomationProperties.AutomationId="ColorCameraImage" /><Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="7" Padding="6,2" CornerRadius="3" Background="#AA000000"><TextBlock Text="COLOR · RGB8" Foreground="White" FontFamily="Cascadia Mono, Consolas" FontSize="10" /></Border></Grid></Border>
                                    <Border Grid.Column="2" Background="#FF101418" CornerRadius="6" ClipToBounds="True" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1"><Grid><Image x:Name="DepthCameraImage" Stretch="Uniform" AutomationProperties.AutomationId="DepthCameraImage" /><Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="7" Padding="6,2" CornerRadius="3" Background="#AA000000"><TextBlock Text="DEPTH · Z16" Foreground="White" FontFamily="Cascadia Mono, Consolas" FontSize="10" /></Border></Grid></Border>
                                </Grid>
                            </Grid>
                        </Border>
                        <Border Grid.Row="2" Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="37" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardHeaderStyle}">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Ellipse Width="7" Height="7" Margin="0,0,6,0" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse" BasedOn="{StaticResource StatusDotStyle}">
                                                        <Setter Property="Fill" Value="{DynamicResource TextFillColorTertiaryBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTeachRecording}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding TeachRecordingSummary}" Style="{StaticResource MetaTextStyle}"
                                                       AutomationProperties.AutomationId="TeachRecordingStatusText" />
                                        </StackPanel>
                                        <TextBlock Text="示教录制" Style="{StaticResource SectionHeaderTextStyle}" />
                                    </DockPanel>
                                </Border>
                                <Grid Grid.Row="1" Margin="10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="1.35*" /><ColumnDefinition Width="10" /><ColumnDefinition Width="1*" /></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="一键录制会自动获取控制权并进入重力补偿拖动示教；回放会先自动移动到录制起点，无需执行校零。"
                                                   FontSize="10.5" TextWrapping="Wrap" Margin="0,0,0,8" />
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="70" /><ColumnDefinition Width="*" /><ColumnDefinition Width="78" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="录制名称" VerticalAlignment="Center" Style="{StaticResource MetricLabelStyle}" />
                                            <TextBox Grid.Column="1" Text="{Binding TeachRecordingName, UpdateSourceTrigger=PropertyChanged}"
                                                     AutomationProperties.AutomationId="TeachRecordingNameBox" />
                                            <TextBlock Grid.Column="2" Text="{Binding TeachRecordingElapsedLabel}" HorizontalAlignment="Right"
                                                       VerticalAlignment="Center" FontFamily="Cascadia Mono, Consolas" FontWeight="Bold" />
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <ui:Button Content="● 开始示教录制" Appearance="Danger"
                                                       Command="{Binding StartTeachSessionCommand}"
                                                       AutomationProperties.AutomationId="StartTeachSessionButton" />
                                            <ui:Button Content="■ 停止并保存" Appearance="Primary"
                                                       Command="{Binding StopTeachSessionCommand}" Margin="7,0,0,0"
                                                       AutomationProperties.AutomationId="StopTeachSessionButton" />
                                            <ui:Button Content="获取控制权" Appearance="Secondary" Command="{Binding AcquireControlCommand}"
                                                       Margin="7,0,0,0" AutomationProperties.AutomationId="TeachAcquireControlButton" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding RecordingPath}" TextTrimming="CharacterEllipsis" Margin="0,8,0,0"
                                                   FontFamily="Cascadia Mono, Consolas" FontSize="10" ToolTip="{Binding RecordingPath}" />
                                    </StackPanel>
                                    <Border Grid.Column="2" Style="{StaticResource CockpitSubtlePanelStyle}" Padding="9,7">
                                        <StackPanel>
                                            <TextBlock Text="高级分步控制" Style="{StaticResource MetricLabelStyle}" />
                                            <TextBlock Text="仅在调试时使用；日常录制请使用左侧一键流程。" FontSize="10" TextWrapping="Wrap" Margin="0,3,0,7" />
                                            <WrapPanel>
                                                <ui:Button Content="开始示教" Appearance="Secondary" Command="{Binding StartTeachCommand}"
                                                           AutomationProperties.AutomationId="StartTeachButton" />
                                                <ui:Button Content="开始写入" Appearance="Secondary" Command="{Binding StartTeachRecordingCommand}"
                                                           Margin="5,0,0,0" AutomationProperties.AutomationId="StartTeachRecordingButton" />
                                                <ui:Button Content="停止写入" Appearance="Transparent" Command="{Binding StopTeachRecordingCommand}"
                                                           Margin="5,0,0,0" AutomationProperties.AutomationId="StopTeachRecordingButton" />
                                                <ui:Button Content="停止示教" Appearance="Transparent" Command="{Binding StopTeachCommand}"
                                                           Margin="5,0,0,0" AutomationProperties.AutomationId="StopTeachButton" />
                                            </WrapPanel>
                                            <TextBlock Text="{Binding TeachStatus}" Margin="0,8,0,0" TextWrapping="Wrap"
                                                       Style="{StaticResource MetaTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions><RowDefinition Height="122" /><RowDefinition Height="9" /><RowDefinition Height="*" /><RowDefinition Height="9" /><RowDefinition Height="190" /></Grid.RowDefinitions>
                        <Border Style="{StaticResource CockpitCardStyle}" ClipToBounds="True"><Grid><Grid.RowDefinitions><RowDefinition Height="36" /><RowDefinition Height="*" /></Grid.RowDefinitions><Border Style="{StaticResource CardHeaderStyle}"><DockPanel><TextBlock DockPanel.Dock="Right" Text="{Binding CameraAvailable}" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="设备信息" Style="{StaticResource SectionHeaderTextStyle}" /></DockPanel></Border><Grid Grid.Row="1" Margin="10,7"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions><DockPanel><TextBlock Text="D405" FontWeight="SemiBold" /><TextBlock DockPanel.Dock="Right" Text="{Binding CameraSummary}" Style="{StaticResource MetaTextStyle}" /></DockPanel><StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0"><ui:Button Content="一键引导" Icon="{ui:SymbolIcon UsbPlug20}" Appearance="Primary" Click="RunEnvironment_Click" AutomationProperties.AutomationId="EnvironmentGuideButton" /><ui:Button Content="只读检测" Appearance="Secondary" Command="{Binding ProbeEnvironmentCommand}" Margin="6,0,0,0" AutomationProperties.AutomationId="ProbeEnvironmentButton" /></StackPanel></Grid></Grid></Border>

                        <Border Grid.Row="2" Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <TabControl Background="Transparent" BorderThickness="0">
                                <TabItem Header="轨迹库">
                                    <Grid Margin="8"><Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="37" /></Grid.RowDefinitions>
                                        <ListBox ItemsSource="{Binding TeachRecordings}" SelectedItem="{Binding SelectedTeachRecording}" BorderThickness="0" Background="Transparent"
                                                 AutomationProperties.AutomationId="TeachRecordingList">
                                            <ListBox.ItemTemplate><DataTemplate><Border Margin="0,2" Padding="8,6" Style="{StaticResource CockpitSubtlePanelStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11" /><TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis" Style="{StaticResource MetaTextStyle}" /></StackPanel><StackPanel Grid.Column="1" HorizontalAlignment="Right"><TextBlock Text="{Binding Summary}" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="{Binding RecordedAt, StringFormat={}{0:MM-dd HH:mm}}" HorizontalAlignment="Right" Style="{StaticResource MetaTextStyle}" /></StackPanel></Grid></Border></DataTemplate></ListBox.ItemTemplate>
                                        </ListBox>
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"><ui:Button Content="刷新" Appearance="Transparent" Command="{Binding RefreshTeachRecordingsCommand}" /><ui:Button Content="POS-VEL 回放" Appearance="Primary" Command="{Binding PlayTeachRecordingCommand}" Margin="6,0,0,0" AutomationProperties.AutomationId="PlayTeachRecordingButton" /><ui:Button Content="取消" Appearance="Secondary" Command="{Binding CancelExecutionCommand}" Margin="6,0,0,0" /></StackPanel>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="系统日志">
                                    <ListBox ItemsSource="{Binding Logs}" BorderThickness="0" Background="Transparent" ItemContainerStyle="{StaticResource LogListItemStyle}"><ListBox.ItemTemplate><DataTemplate><Grid Margin="8,3"><Grid.ColumnDefinitions><ColumnDefinition Width="80" /><ColumnDefinition Width="65" /><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Style="{StaticResource MetaTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding Level}" FontWeight="Bold" FontSize="10" /><TextBlock Grid.Column="2" Text="{Binding Source}" Style="{StaticResource MetaTextStyle}" /><TextBlock Grid.Column="3" Text="{Binding Message}" TextTrimming="CharacterEllipsis" FontSize="10" /></Grid></DataTemplate></ListBox.ItemTemplate></ListBox>
                                </TabItem>
                                <TabItem Header="环境引导">
                                    <ListView ItemsSource="{Binding EnvironmentSteps}" BorderThickness="0" Background="Transparent"><ListView.View><GridView><GridViewColumn Header="步骤" Width="120" DisplayMemberBinding="{Binding Name}" /><GridViewColumn Header="结果" Width="60" DisplayMemberBinding="{Binding Success}" /><GridViewColumn Header="说明" Width="270" DisplayMemberBinding="{Binding Detail}" /></GridView></ListView.View></ListView>
                                </TabItem>
                            </TabControl>
                        </Border>

                        <Border Grid.Row="4" Style="{StaticResource CockpitCardStyle}" ClipToBounds="True">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="36" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <Border Style="{StaticResource CardHeaderStyle}"><DockPanel><TextBlock DockPanel.Dock="Right" Text="{Binding DatasetStatus}" Style="{StaticResource MetaTextStyle}" /><TextBlock Text="LeRobotDataset v3 导出" Style="{StaticResource SectionHeaderTextStyle}" /></DockPanel></Border>
                                <Grid Grid.Row="1" Margin="10"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="34" /></Grid.RowDefinitions>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="78" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="Repo ID" VerticalAlignment="Center" FontSize="10" /><TextBox Grid.Column="1" Text="{Binding DatasetRepoId}" /></Grid>
                                    <Grid Grid.Row="1" Margin="0,5,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="78" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="Task" VerticalAlignment="Center" FontSize="10" /><TextBox Grid.Column="1" Text="{Binding DatasetTask}" /></Grid>
                                    <ProgressBar Grid.Row="2" Height="7" Margin="0,8,0,0" Maximum="100" Value="{Binding DatasetProgress}" />
                                    <TextBlock Grid.Row="3" Text="{Binding DatasetResult}" TextTrimming="CharacterEllipsis" Margin="0,6,0,0" Style="{StaticResource MetaTextStyle}" />
                                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"><ui:Button Content="取消导出" Appearance="Transparent" Command="{Binding CancelDatasetExportCommand}" /><ui:Button Content="导出数据集" Appearance="Primary" Command="{Binding ExportDatasetCommand}" Margin="6,0,0,0" AutomationProperties.AutomationId="ExportDatasetButton" /></StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="4" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <DockPanel Margin="10,0">
                <TextBlock DockPanel.Dock="Right" Text="Ctrl + / − 缩放 · Ctrl+0 重置 · F12 急停 · Esc 取消" Style="{StaticResource MetaTextStyle}" />
                <Ellipse Width="6" Height="6" Fill="{DynamicResource SystemFillColorSuccessBrush}" Margin="0,0,7,0" />
                <TextBlock Text="Linux control plane" FontFamily="Cascadia Mono, Consolas" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="  ·  Exact CAD / armd / camerad" Margin="6,0,0,0" Style="{StaticResource MetaTextStyle}" />
            </DockPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
