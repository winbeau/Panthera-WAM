<Window x:Class="Panthera.Terminal.App.SshDeploymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="SSH 连接"
        Width="520" Height="400" MinWidth="520" MinHeight="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" ShowInTaskbar="False"
        FontFamily="Segoe UI Variable Text, Microsoft YaHei UI, Segoe UI"
        Background="Transparent"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        AutomationProperties.AutomationId="SshDeploymentDialog">
    <Window.Resources>
        <Style x:Key="ChromelessCloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="10">
        <Grid Margin="22,12,22,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="SSH 连接" FontSize="20" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="DiscoveryText" Grid.Column="1" Margin="0,0,8,0"
                           FontSize="11.5" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <Button Grid.Column="2" Content="×" Width="32" Height="32"
                        FontSize="19" IsCancel="True" Cursor="Hand"
                        Style="{StaticResource ChromelessCloseButtonStyle}"
                        AutomationProperties.AutomationId="CancelSshDeploymentButton" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,6,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="48" />
                    <RowDefinition Height="48" />
                    <RowDefinition Height="48" />
                    <RowDefinition Height="42" />
                </Grid.RowDefinitions>

                <TextBlock Text="主机 / IP" VerticalAlignment="Center" />
                <ComboBox x:Name="HostBox" Grid.Column="1" Height="34" IsEditable="True"
                          IsTextSearchEnabled="True" TextSearch.TextPath="Host"
                          VerticalContentAlignment="Center" SelectionChanged="HostBox_SelectionChanged"
                          AutomationProperties.AutomationId="SshHostBox">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="1,3">
                                <TextBlock Text="{Binding Host}" FontFamily="Cascadia Mono, Consolas" />
                                <TextBlock Text="{Binding Source}" FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <ui:Button x:Name="RefreshCandidatesButton" Grid.Column="2" Content="探测" Height="34"
                           Margin="7,0,0,0" Appearance="Secondary" Click="RefreshCandidates_Click"
                           AutomationProperties.AutomationId="RefreshSshCandidatesButton" />

                <TextBlock Grid.Row="1" Text="端口" VerticalAlignment="Center" />
                <TextBox x:Name="PortBox" Grid.Row="1" Grid.Column="1" Width="110" Height="34"
                         HorizontalAlignment="Left" VerticalContentAlignment="Center"
                         AutomationProperties.AutomationId="SshPortBox" />

                <TextBlock Grid.Row="2" Text="用户名" VerticalAlignment="Center" />
                <ComboBox x:Name="UserBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Height="34"
                          IsEditable="True" IsTextSearchEnabled="True" VerticalContentAlignment="Center"
                          AutomationProperties.AutomationId="SshUserBox" />

                <TextBlock Grid.Row="3" Text="私钥文件（可选）" VerticalAlignment="Center" />
                <TextBox x:Name="IdentityFileBox" Grid.Row="3" Grid.Column="1" Height="34"
                         Margin="0,0,7,0" VerticalContentAlignment="Center"
                         AutomationProperties.AutomationId="SshIdentityFileBox" />
                <ui:Button Grid.Row="3" Grid.Column="2" Content="浏览" Height="34"
                           Appearance="Secondary" Click="BrowseIdentity_Click"
                           AutomationProperties.AutomationId="BrowseSshIdentityButton" />

                <CheckBox x:Name="AcceptHostKeyBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                          Content="自动接受新主机指纹（accept-new）"
                          VerticalAlignment="Center" AutomationProperties.AutomationId="AcceptSshHostKeyBox" />
            </Grid>

            <TextBlock x:Name="ValidationText" Grid.Row="2" MinHeight="22" Margin="0,2,0,8"
                       TextWrapping="Wrap" Foreground="{DynamicResource SystemFillColorCriticalBrush}" />

            <ui:Button Grid.Row="3" Content="探测并启动" Width="122" Height="36"
                       HorizontalAlignment="Right" Appearance="Primary" Click="Submit_Click"
                       AutomationProperties.AutomationId="SubmitSshDeploymentButton" />
        </Grid>
    </Border>
</Window>
